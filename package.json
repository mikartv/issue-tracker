{
  "name": "issue-tracker",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:db": "docker compose up -d db",
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run start -w apps/web",
    "test:all": "npm run test:api && npm run test:web",
    "test:api": "npm run test -w apps/api",
    "test:web": "npm run test -w apps/web"
  }
}
